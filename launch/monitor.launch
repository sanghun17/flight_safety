<launch>
  <!-- L2 monitor: /diagnostics -> worst fault -> /flight_safety/fault (observe-only). -->
  <arg name="config" default="$(find flight_safety)/config/monitor.yaml"/>
  <node pkg="flight_safety" type="monitor_node.py" name="flight_safety_monitor" output="screen">
    <rosparam command="load" file="$(arg config)"/>
  </node>
</launch>
