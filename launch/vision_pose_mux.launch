<launch>
  <!-- Estimator MUX (peer of the L3 response mux): select ONE odometry source -> /mavros/vision_pose/pose
       (PX4 EKF2 vision input). The mux subscribes DIRECTLY to the VRPN tracker pose /vrpn_client_node/pure/pose
       (mocap) and FAST-LIVO's /aft_mapped_to_body (vio) — both PoseStamped, no throttle/relay in between; mocap
       arrives at the VRPN update_frequency (100Hz). topic_tools/mux passes only the selected one so EKF2 never
       sees two publishers (which would make it jitter between them). Response mux = control OUTPUT; this =
       estimator INPUT. FAST-LIVO must run body_calib_en:=true so it does NOT also publish /mavros/vision_pose/pose
       itself (LIVMapper publish_mavros is gated on !body_calib_en) — else two publishers on the vio path.

       STATIC select at launch:   source:=mocap | vio   (default mocap = VRPN, the absolute reference).
       Live switch:
         rosservice call /vision_pose_mux/select "topic: '/aft_mapped_to_body'"
       Current input echoes on /vision_pose_mux/selected.
       NOTE: /aft_mapped_to_body is the LIVO-world (W_L) body pose, NOT origin-aligned to the OptiTrack
       frame, so a mid-flight mocap<->vio switch steps by the frame offset (intended for vio-led flight
       where EKF2 self-aligns to W_L). The GT-anchored /aft_mapped_to_optitrack is eval-only.

       NOTE: the selected source feeds EKF2; its fused output (/mavros/local_position/odom) is relayed
       to /robot/odom below, so the PLANNER/CONTROL odom always follows this same mux choice (replaces
       the old planner=vio-while-EKF2=mocap decoupling; /system/localization no longer picks a separate
       planner odom source). -->
  <arg name="source"      default="mocap"/>             <!-- mocap | vio -->
  <arg name="mocap_topic" default="/vrpn_client_node/pure/pose"/>
  <arg name="vio_topic"   default="/aft_mapped_to_body"/>
  <node pkg="topic_tools" type="mux" name="vision_pose_mux" output="screen"
        launch-prefix="taskset -c $(optenv CPUS_POOL 4-11)"
        args="/mavros/vision_pose/pose $(arg mocap_topic) $(arg vio_topic)">
    <param name="initial_topic" value="$(arg vio_topic)"   if="$(eval arg('source') == 'vio')"/>
    <param name="initial_topic" value="$(arg mocap_topic)" unless="$(eval arg('source') == 'vio')"/>
  </node>

  <!-- PX4's fused estimate (EKF2 output, following whichever vision source the mux selected) ->
       /robot/odom = /system/odom_topic, the planner/control odom. SINGLE producer of /robot/odom for
       real flight (real_planning.launch no longer relays FAST-LIVO). Odometry carries twist, so the
       controller's velocity term is real. Flows only once mavros is up + EKF2 has converged. -->
  <node pkg="topic_tools" type="relay" name="robot_odom_relay"
        launch-prefix="taskset -c $(optenv CPUS_POOL 4-11)"
        args="/mavros/local_position/odom /robot/odom"/>
</launch>
